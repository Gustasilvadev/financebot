# =========================================================
#  FinanceBot — Variáveis de Ambiente (MODELO)
#  Copie este arquivo para ".env" e preencha os valores.
#  O .env NÃO é versionado (está no .gitignore).
# =========================================================

# ── Telegram ─────────────────────────────────────────────
# Token do bot, gerado pelo @BotFather.
BOT_TOKEN=

# Seu ID numérico pessoal do Telegram (descubra com o @userinfobot).
# APENAS este ID conseguirá interagir com o bot.
TELEGRAM_USER_ID=

# ── Supabase ─────────────────────────────────────────────
# URL do projeto (Supabase > Project Settings > API).
SUPABASE_URL=

# Chave service_role (Supabase > Project Settings > API).
# ATENÇÃO: acesso ADMIN, ignora o RLS. Trate como senha, nunca exponha.
SUPABASE_SERVICE_ROLE_KEY=

# ── Runtime ──────────────────────────────────────────────
# "development" => long polling | "production" => webhook
NODE_ENV=development

# Usado apenas em produção (webhook). Ex.: https://financebot.onrender.com
WEBHOOK_DOMAIN=

# Porta do servidor de webhook (o Render injeta isto automaticamente).
PORT=3000
